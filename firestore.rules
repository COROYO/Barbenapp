rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isMemberOf(babyId) {
      return isSignedIn()
        && request.auth.uid in get(/databases/$(database)/documents/babies/$(babyId)).data.memberIds;
    }

    match /babies/{babyId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.memberIds;

      allow create: if isSignedIn()
        && request.auth.uid in request.resource.data.memberIds
        && request.resource.data.createdBy == request.auth.uid;

      // Either already a member, or joining via invite (only adds self to memberIds)
      allow update: if isSignedIn() && (
        (request.auth.uid in resource.data.memberIds)
        ||
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberIds'])
          && request.resource.data.memberIds.hasAll(resource.data.memberIds)
          && request.resource.data.memberIds.size() == resource.data.memberIds.size() + 1
          && request.auth.uid in request.resource.data.memberIds
        )
      );

      allow delete: if isSignedIn() && request.auth.uid in resource.data.memberIds;

      match /feedings/{feedingId} {
        allow read, write: if isMemberOf(babyId);
      }

      match /sleepSessions/{sleepId} {
        allow read, write: if isMemberOf(babyId);
      }
    }

    match /invites/{code} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.createdBy == request.auth.uid;
      allow delete: if isSignedIn();
    }

    match /users/{uid} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
    }

    // Personal login codes are managed exclusively by Cloud Functions
    // (Admin SDK bypasses these rules); clients must never read or write.
    match /loginCodes/{code} {
      allow read, write: if false;
    }
  }
}
